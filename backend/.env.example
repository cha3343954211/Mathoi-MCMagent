# ============== 全局 ==============
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
WORKSPACE_DIR=./workspace
# 生产环境建议填写具体域名，如 https://example.com; 开发/内网 可用 *
CORS_ORIGINS=*

# ============== Redis（可选，未配置则使用内存存储） ==============
REDIS_URL=

# ============== 数据库 ==============
# 默认 SQLite（零配置）；上云推荐：postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./mathoi.db

# ============== 认证 ==============
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# 是否允许公开注册（false 则仅管理员可创建用户）
ALLOW_REGISTER=true

# 默认管理员（首次启动自动创建，已存在则忽略）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@example.com

# ============== LLM 后端 ==============
# openai = OpenAI 兼容协议直连； litellm = 统一通过 LiteLLM 转发
LLM_BACKEND=openai

# ============== 默认模型（兜底） ==============
DEFAULT_BASE_URL=https://api.deepseek.com/v1
DEFAULT_API_KEY=sk-your-key-here
DEFAULT_MODEL=deepseek-chat
DEFAULT_TEMPERATURE=0.3

# ============== 多模型协同（每个 Agent 可独立覆盖） ==============
# Modeler：建模 / 数学推理，建议用强推理模型
MODELER_MODEL=
MODELER_BASE_URL=
MODELER_API_KEY=
MODELER_TEMPERATURE=0.2

# Coder：代码生成 / 数据分析，建议用代码能力强的模型
CODER_MODEL=
CODER_BASE_URL=
CODER_API_KEY=
CODER_TEMPERATURE=0.1

# Writer：论文撰写，建议用语言流畅的模型
WRITER_MODEL=
WRITER_BASE_URL=
WRITER_API_KEY=
WRITER_TEMPERATURE=0.5

# ============== 沙箱 ==============
SANDBOX_TIMEOUT=120
SANDBOX_KERNEL=python3

# ============== 工作流 ==============
MAX_CODER_ITERATIONS=8
MAX_REVISION_ROUNDS=2
